# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb://localhost:27017/onthespot

# JWT secret for auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Seed master admin (used by `npm run seed`)
ADMIN_SEED_NAME=Master Admin
ADMIN_SEED_EMAIL=admin@onthespot.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# Server
PORT=3001
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000

# Public base URL of THIS service (used to build absolute upload URLs)
PUBLIC_BASE_URL=http://localhost:3001
